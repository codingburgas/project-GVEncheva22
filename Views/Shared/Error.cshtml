@model ErrorViewModel

@{
    ViewData["Title"] = "Error"; // Page title shown in browser tab
}

<!-- Main error heading -->
<h1 class="text-danger">Error.</h1>

<!-- General error message -->
<h2 class="text-danger">
    An error occurred while processing your request.
</h2>

<!-- Show Request ID only if available -->
@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong>
        <code>@Model.RequestId</code>
    </p>
}

<!-- Development mode explanation -->
<h3>Development Mode</h3>

<p>
    Switching to <strong>Development</strong> environment will display more detailed
    information about the error that occurred.
</p>

<p>
    <strong>
        The Development environment shouldn't be enabled for deployed applications.
    </strong>

    It can expose sensitive information from exceptions to end users.

    For local debugging, enable the <strong>Development</strong> environment by setting
    the <strong>ASPNETCORE_ENVIRONMENT</strong> variable to <strong>Development</strong>
    and restarting the application.
</p>