<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - project_GVEncheva22</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project_GVEncheva22.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="bg-white border-bottom shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container-xl">
                <a class="navbar-brand d-flex align-items-center gap-2 fw-bold text-uppercase text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="navbar-brand-icon rounded-circle bg-primary text-white d-inline-flex justify-content-center align-items-center">T</span>
                    <span>TaskFlow</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Board" asp-action="Index">Boards</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Task" asp-action="Index">Tasks</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Task" asp-action="GroupedByStatus">Grouped Tasks</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center ms-lg-4 mt-3 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xl py-5">
        <main role="main" class="mx-auto bg-white rounded-4 shadow-sm p-4 p-lg-5" style="max-width: 1200px;">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-top text-muted py-4">
        <div class="container-xl d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="mb-0 small">&copy; 2026 project_GVEncheva22</p>
            <p class="mb-0 small">Built with Bootstrap 5 · <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></p>
        </div>
    </footer>
    <script>
        window.mgt = window.mgt || {};
        if (typeof window.mgt.clearMarks !== "function") {
            window.mgt.clearMarks = function () { };
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
