<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <!-- Responsive design settings -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Dynamic page title -->
    <title>@ViewData["Title"] - TaskFlow</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/project_GVEncheva22.styles.css" asp-append-version="true" />
</head>

<body class="premium-layout">

    <!-- HEADER / NAVBAR -->
    <header class="premium-header">
        <nav class="navbar navbar-expand-lg navbar-light py-4">

            <div class="container-fluid px-4">

                <!-- Brand / Logo -->
                <a class="navbar-brand premium-brand d-flex align-items-center gap-3 fw-bold text-uppercase"
                   asp-area="" asp-controller="Home" asp-action="Index">

                    <!-- Logo icon -->
                    <div class="brand-icon-wrapper">
                        <span class="brand-icon rounded-3 bg-gradient-primary text-white d-inline-flex justify-content-center align-items-center shadow-lg">
                            <i class="bi bi-check2-all fs-4"></i>
                        </span>
                    </div>

                    <!-- Brand text -->
                    <div class="brand-text">
                        <span class="brand-main">TaskFlow</span>
                        <span class="brand-subtitle small text-muted d-block fw-normal">
                            Project Management
                        </span>
                    </div>

                </a>

                <!-- Mobile menu toggle button -->
                <button class="navbar-toggler border-0 shadow-none premium-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- NAVIGATION MENU -->
                <div class="collapse navbar-collapse premium-nav-collapse" id="mainNavbar">

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center gap-1">

                        <!-- Home -->
                        <li class="nav-item">
                            <a class="nav-link premium-nav-link"
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-2"></i>Home
                            </a>
                        </li>

                        <!-- Boards -->
                        <li class="nav-item">
                            <a class="nav-link premium-nav-link"
                               asp-controller="Board" asp-action="Index">
                                <i class="bi bi-kanban me-2"></i>Boards
                            </a>
                        </li>

                        <!-- Tasks -->
                        <li class="nav-item">
                            <a class="nav-link premium-nav-link"
                               asp-controller="Task" asp-action="Index">
                                <i class="bi bi-list-check me-2"></i>Tasks
                            </a>
                        </li>

                        <!-- Grouped tasks -->
                        <li class="nav-item">
                            <a class="nav-link premium-nav-link"
                               asp-controller="Task" asp-action="GroupedByStatus">
                                <i class="bi bi-diagram-3 me-2"></i>Grouped Tasks
                            </a>
                        </li>

                        <!-- Dashboard -->
                        <li class="nav-item">
                            <a class="nav-link premium-nav-link"
                               asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-graph-up me-2"></i>Dashboard
                            </a>
                        </li>

                    </ul>

                    <!-- Login / Register partial view -->
                    <div class="d-flex align-items-center ms-lg-4 mt-4 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT AREA -->
    <main class="premium-main">
        <div class="container-fluid px-4 py-5">

            <!-- Page-specific content will be rendered here -->
            <div class="premium-content-wrapper">
                @RenderBody()
            </div>

        </div>
    </main>

    <!-- FOOTER -->
    <footer class="premium-footer bg-white border-top">
        <div class="container-fluid px-4 py-4">

            <div class="row align-items-center">

                <!-- Left side -->
                <div class="col-md-6">
                    <div class="footer-brand mb-2 mb-md-0">
                        <span class="fw-bold text-primary">TaskFlow</span>
                        <span class="text-muted ms-2">© 2026. Built with excellence.</span>
                    </div>
                </div>

                <!-- Right side links -->
                <div class="col-md-6 text-md-end">
                    <div class="footer-links">
                        <a href="#" class="text-muted text-decoration-none me-3">Privacy</a>
                        <a href="#" class="text-muted text-decoration-none me-3">Terms</a>
                        <a href="#" class="text-muted text-decoration-none">Support</a>
                    </div>
                </div>

            </div>
        </div>
    </footer>

    <!-- JS workaround / safety script -->
    <script>
        window.mgt = window.mgt || {};
        if (typeof window.mgt.clearMarks !== "function") {
            window.mgt.clearMarks = function () { };
        }
    </script>

    <!-- JavaScript libraries -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>