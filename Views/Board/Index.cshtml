@model IEnumerable<project_GVEncheva22.Models.Board>

@{
    ViewData["Title"] = "Boards"; // Page title in browser tab
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">

            <!-- Header section (title + create button) -->
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h1 class="text-primary mb-1">Boards</h1>
                    <p class="text-muted">Organize your projects into boards</p>
                </div>

                <!-- Button to create new board -->
                <a asp-action="Create" class="btn btn-success btn-lg btn-create-task">
                    <i class="bi bi-plus-circle"></i> Create New Board
                </a>
            </div>

            <!-- If there are no boards, show an info message -->
            @if (!Model.Any())
            {
                <div class="alert alert-info" role="alert">
                    <h4 class="alert-heading">No Boards Found</h4>
                    <p>Get started by creating your first board.</p>
                    <hr>

                    <!-- Button to create first board -->
                    <p class="mb-0">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Create Your First Board
                        </a>
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                            <div class="card h-100 board-card">
                                <div class="card-body d-flex flex-column">

                                    <!-- Board title + menu -->
                                    <div class="d-flex justify-content-between align-items-start mb-3">

                                        <!-- Board title -->
                                        <h5 class="card-title text-primary mb-0 flex-grow-1">@Html.DisplayFor(modelItem => item.Title)</h5>

                                        <!-- Board actions -->
                                        <div class="board-menu">
                                            <div class="dropdown">

                                                <!-- Menu button -->
                                                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots"></i>
                                                </button>

                                                <!-- Dropdown actions -->
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> View Details</a></li>
                                                    <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Edit</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Delete</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Task statistics section -->
                                    <div class="board-stats mb-3">
                                        <div class="row text-center">

                                            <!-- Total tasks -->
                                            <div class="col-4">
                                                <div class="stat-number text-primary">@item.TaskItems.Count</div>
                                                <small class="text-muted">Total</small>
                                            </div>

                                            <!-- Done tasks -->
                                            <div class="col-4">
                                                <div class="stat-number text-success">@item.TaskItems.Count(t => t.Status == Status.Done)</div>
                                                <small class="text-muted">Done</small>
                                            </div>

                                            <!-- In Progress tasks -->
                                            <div class="col-4">
                                                <div class="stat-number text-warning">@item.TaskItems.Count(t => t.Status == Status.InProgress)</div>
                                                <small class="text-muted">Active</small>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Creation date -->
                                    <div class="board-meta text-muted small mb-3">
                                        <i class="bi bi-calendar-event"></i> Created @item.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                    
                                    <!-- Open board button -->
                                    <div class="mt-auto">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm w-100">
                                            <i class="bi bi-arrow-right-circle"></i> Open Board
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
