@{
    // Sets the page title shown in the browser tab
    ViewData["Title"] = "Register";
    Layout = null;
    var postedEmail = Context.Request.HasFormContentType ? Context.Request.Form["email"].ToString() : string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <!-- Enables responsive design on all devices -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title -->
    <title>@ViewData["Title"] - TaskFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            margin-bottom: 0;
        }
    </style>
</head>

<!-- Applies custom styling for login/register pages -->
<body class="login-page">
    <div class="login-container">
        <div class="login-card">

            <!-- Header section -->
            <div class="login-card-header">
                <h2>Join TaskFlow</h2>
                <p>Create your account to get started</p>
            </div>

            <!-- Registration form -->
            <div class="login-card-body">
                <form method="post" asp-action="Register">

                    <!-- Displays validation errors -->
                    <div asp-validation-summary="All" class="auth-feedback" role="alert"></div>

                    <!-- Email input field -->
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" name="email" value="@postedEmail" placeholder="Email address" required autofocus>
                        <label for="email">Email Address</label>
                        <span class="auth-field-message" data-valmsg-for="email"></span>
                    </div>

                    <!-- Password input field -->
                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                        <label for="password">Password</label>
                        <span class="auth-field-message" data-valmsg-for="password"></span>
                    </div>

                    <!-- Confirm password input field -->
                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm password" required>
                        <label for="confirmPassword">Confirm Password</label>
                        <span class="auth-field-message" data-valmsg-for="confirmPassword"></span>
                    </div>

                    <!-- Submit button -->
                    <button type="submit" class="btn login-btn">
                        <span>Create Account</span>
                    </button>

                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                </form>
            </div>

            <div class="login-footer">
                <p class="mb-2">
                    Already have an account?
                    <a href="/Account/Login">Sign in here</a>
                </p>
                <p class="mb-0">
                    <a href="/Identity/Account/ForgotPassword">Forgot your password?</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
