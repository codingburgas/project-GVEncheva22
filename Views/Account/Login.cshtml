@{
    ViewData["Title"] = "Log In";
    Layout = null;
    var postedEmail = Context.Request.HasFormContentType ? Context.Request.Form["email"].ToString() : string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title -->
    <title>@ViewData["Title"] - TaskFlow</title>

    <!-- Google font for modern typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom site styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Page-specific styling -->
    <style>
        body {
            margin-bottom: 0;
        }
    </style>
</head>

<!-- Custom class used for login page styling -->
<body class="login-page">
    <div class="login-container">
        <div class="login-card">

            <!-- Header section with title and subtitle -->
            <div class="login-card-header">
                <h2>Welcome Back</h2>
                <p>Sign in to your TaskFlow account</p>
            </div>

            <!-- Login form -->
            <div class="login-card-body">
                <form method="post" asp-action="Login">

                    <!-- Displays error message if login fails -->
                    <div asp-validation-summary="All" class="auth-feedback" role="alert"></div>

                    <!-- Email input field -->
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" name="email" value="@postedEmail" placeholder="Email address" required autofocus>
                        <label for="email">Email Address</label>
                        <span class="auth-field-message" data-valmsg-for="email"></span>
                    </div>

                    <!-- Password input field -->
                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                        <label for="password">Password</label>
                        <span class="auth-field-message" data-valmsg-for="password"></span>
                    </div>

                    <!-- Remember me checkbox -->
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
                        <label class="form-check-label" for="rememberMe">
                            Remember me
                        </label>
                    </div>

                    <!-- Submit button -->
                    <button type="submit" class="btn login-btn">
                        <span>Sign In</span>
                    </button>

                    <!-- Hidden field for redirecting after login -->
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                </form>
            </div>

            <div class="login-footer">
                <p class="mb-2">
                    Don't have an account? 
                    <a href="/Account/Register">Create one here</a>
                </p>
                <p class="mb-0">
                    <a href="/Identity/Account/ForgotPassword">Forgot your password?</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
