@{
    ViewData["Title"] = "Dashboard"; // Page title in browser tab
}

<!-- Show welcome message only for non-authenticated users -->
@if (!User.Identity.IsAuthenticated)
{
    <div class="premium-alert premium-alert-info alert-dismissible fade show mb-5" role="alert">
        <div class="d-flex align-items-center">

            <!-- Info icon -->
            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
            <div>

                <!-- Welcome heading -->
                <h5 class="alert-heading mb-1">Welcome to TaskFlow!</h5>

                <!-- Short description -->
                <p class="mb-2">Organize your tasks in boards, lists and cards (Trello-style).</p>

                <!-- Authentication buttons -->
                <div class="mt-3">
                    <a href="/Account/Login" class="premium-btn premium-btn-primary me-2">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                    <a href="/Account/Register" class="premium-btn premium-btn-secondary">
                        <i class="bi bi-person-plus"></i> Create Account
                    </a>
                </div>
            </div>
        </div>

        <!-- Close button for alert -->
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-5">
    <div class="col-12">
        <div class="text-center mb-5">

            <!-- Main title -->
            <h1 class="display-4 fw-bold text-gradient mb-3">
                <i class="bi bi-kanban text-primary me-3"></i>
                TaskFlow Dashboard
            </h1>

            <!-- Subtitle -->
            <p class="lead text-muted">Streamline your workflow with our intuitive project management platform</p>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-4 mb-5">

    <!-- Total tasks -->
    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stats-card stats-primary h-100">
            <div class="stats-icon">
                <i class="bi bi-list-check"></i>
            </div>
            <div class="stats-value">@ViewBag.TotalTasks</div>
            <div class="stats-title">Total Tasks</div>
            <div class="stats-description">All tasks in your workspace</div>
        </div>
    </div>

    <!-- Completed tasks -->
    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stats-card stats-success h-100">
            <div class="stats-icon">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="stats-value">@ViewBag.CompletedTasks</div>
            <div class="stats-title">Completed</div>
            <div class="stats-description">Tasks successfully finished</div>
        </div>
    </div>

    <!-- Completion percentage -->
    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stats-card stats-warning h-100">
            <div class="stats-icon">
                <i class="bi bi-graph-up"></i>
            </div>
            <div class="stats-value">@ViewBag.CompletionPercentage.ToString("F1")%</div>
            <div class="stats-title">Completion Rate</div>
            <div class="stats-description">Overall progress percentage</div>
        </div>
    </div>

    <!-- Overdue tasks -->
    <div class="col-xl-3 col-lg-6 col-md-6">
        <div class="stats-card stats-danger h-100">
            <div class="stats-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="stats-value">@ViewBag.OverdueTasks</div>
            <div class="stats-title">Overdue</div>
            <div class="stats-description">Tasks past their deadline</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-5">
    <div class="col-12">
        <div class="premium-card">

            <!-- Section header -->
            <div class="premium-card-header">
                <i class="bi bi-rocket-takeoff me-2"></i>
                Quick Actions
            </div>
            <div class="premium-card-body">
                <div class="row g-3">

                    <!-- Create new board -->
                    <div class="col-md-3 col-sm-6">
                        <a href="@Url.Action("Create", "Board")" class="text-decoration-none">
                            <div class="action-card text-center p-4 rounded-3 border h-100 d-flex flex-column justify-content-center align-items-center" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%); border-color: rgba(102, 126, 234, 0.2); transition: all 0.3s ease;">
                                <i class="bi bi-plus-circle fs-1 text-primary mb-3"></i>
                                <h6 class="mb-1">New Board</h6>
                                <small class="text-muted">Create a project board</small>
                            </div>
                        </a>
                    </div>

                     <!-- Create new task -->
                    <div class="col-md-3 col-sm-6">
                        <a href="@Url.Action("Create", "Task")" class="text-decoration-none">
                            <div class="action-card text-center p-4 rounded-3 border h-100 d-flex flex-column justify-content-center align-items-center" style="background: linear-gradient(135deg, rgba(79, 172, 254, 0.1) 0%, rgba(0, 242, 254, 0.1) 100%); border-color: rgba(79, 172, 254, 0.2); transition: all 0.3s ease;">
                                <i class="bi bi-plus-square fs-1 text-info mb-3"></i>
                                <h6 class="mb-1">New Task</h6>
                                <small class="text-muted">Add a new task</small>
                            </div>
                        </a>
                    </div>

                    <!-- View boards -->
                    <div class="col-md-3 col-sm-6">
                        <a href="@Url.Action("Index", "Board")" class="text-decoration-none">
                            <div class="action-card text-center p-4 rounded-3 border h-100 d-flex flex-column justify-content-center align-items-center" style="background: linear-gradient(135deg, rgba(250, 112, 154, 0.1) 0%, rgba(254, 225, 64, 0.1) 100%); border-color: rgba(250, 112, 154, 0.2); transition: all 0.3s ease;">
                                <i class="bi bi-kanban fs-1 text-warning mb-3"></i>
                                <h6 class="mb-1">View Boards</h6>
                                <small class="text-muted">Manage your boards</small>
                            </div>
                        </a>
                    </div>

                    <!-- Analytics -->
                    <div class="col-md-3 col-sm-6">
                        <a href="@Url.Action("Index", "Dashboard")" class="text-decoration-none">
                            <div class="action-card text-center p-4 rounded-3 border h-100 d-flex flex-column justify-content-center align-items-center" style="background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(238, 90, 36, 0.1) 100%); border-color: rgba(255, 107, 107, 0.2); transition: all 0.3s ease;">
                                <i class="bi bi-bar-chart fs-1 text-danger mb-3"></i>
                                <h6 class="mb-1">Analytics</h6>
                                <small class="text-muted">View detailed reports</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Upcoming deadlines section (only if there are tasks) -->
@if (ViewBag.UpcomingDeadlines != null && ViewBag.UpcomingDeadlines.Count > 0)
{
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="premium-card">

                <!-- Header -->
                <div class="premium-card-header">
                    <i class="bi bi-calendar-event me-2"></i>
                    Upcoming Deadlines
                </div>
                <div class="premium-card-body">
                    <div class="row g-3">

                        <!-- Loop through tasks with deadlines -->
                        @foreach (var task in ViewBag.UpcomingDeadlines)
                        {
                            // Calculate urgency based on days left
                            var daysUntil = (task.Deadline.Value - DateTime.Now).Days;
                            var urgencyClass = daysUntil <= 1 ? "border-danger" : daysUntil <= 3 ? "border-warning" : "border-success";
                            var urgencyBg = daysUntil <= 1 ? "rgba(220, 53, 69, 0.05)" : daysUntil <= 3 ? "rgba(255, 193, 7, 0.05)" : "rgba(25, 135, 84, 0.05)";
                            <div class="col-md-6">
                                <div class="deadline-item p-3 rounded-3 border-start border-4 @urgencyClass" style="background: @urgencyBg;">

                                    <!-- Task title + urgency badge -->
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="mb-1 fw-bold">@task.Title</h6>
                                        <span class="badge @(daysUntil <= 1 ? "bg-danger" : daysUntil <= 3 ? "bg-warning" : "bg-success")">
                                            @daysUntil days
                                        </span>
                                    </div>

                                    <!-- Board name -->
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-folder me-1"></i>@task.Board.Title
                                    </p>

                                    <!-- Deadline date -->
                                    <div class="text-end">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar me-1"></i>@task.Deadline.Value.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
