@model IEnumerable<project_GVEncheva22.Models.TaskItem>

@{
    ViewData["Title"] = "Tasks";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h1 class="text-primary mb-1">Tasks</h1>
                    <p class="text-muted">Manage and organize your tasks</p>
                </div>
                <a asp-action="Create" class="btn btn-success btn-lg btn-create-task">
                    <i class="bi bi-plus-circle"></i> Create New Task
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info role-alert">
                    <h4 class="alert-heading">No Tasks Found</h4>
                    <p>Get started by creating your first task.</p>
                    <hr>
                    <p class="mb-0">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Create Your First Task
                        </a>
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                            <div class="task-card card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title text-primary mb-0 flex-grow-1">@Html.DisplayFor(modelItem => item.Title)</h5>
                                        <span class="badge bg-@(item.Status == project_GVEncheva22.Models.Status.Done ? "success" : item.Status == project_GVEncheva22.Models.Status.InProgress ? "primary" : "secondary") rounded-pill ms-2">
                                            @item.Status
                                        </span>
                                    </div>
                                    
                                    <div class="task-meta mb-3">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="bi bi-folder text-muted me-2"></i>
                                            <small class="text-muted">@Html.DisplayFor(modelItem => item.Board.Title)</small>
                                        </div>
                                        
                                        @if (item.Deadline.HasValue)
                                        {
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-calendar-event @(item.Deadline < DateTime.Now ? "text-danger" : "text-muted") me-2"></i>
                                                <small class="@(item.Deadline < DateTime.Now ? "text-danger fw-bold" : "text-muted")">
                                                    @item.Deadline.Value.ToString("MMM dd, yyyy")
                                                </small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-calendar-x text-muted me-2"></i>
                                                <small class="text-muted">No deadline</small>
                                            </div>
                                        }
                                    </div>
                                    
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="priority-badge badge rounded-pill @(item.Priority == project_GVEncheva22.Models.Priority.High ? "priority-high" : item.Priority == project_GVEncheva22.Models.Priority.Medium ? "priority-medium" : "priority-low")">
                                            @if (item.Priority == project_GVEncheva22.Models.Priority.High)
                                            {
                                                <i class="bi bi-exclamation-circle-fill me-1"></i>
                                            }
                                            else if (item.Priority == project_GVEncheva22.Models.Priority.Medium)
                                            {
                                                <i class="bi bi-dash-circle-fill me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check-circle-fill me-1"></i>
                                            }
                                            @item.Priority
                                        </span>
                                        
                                        <div class="task-actions">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-1" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>